# ============================================
# NEXO ARTICLES - Variables de Entorno
# ============================================
# Copia este archivo como .env.local y completa los valores
# cp .env.example .env.local

# --- API de IA (obligatorio para agentes autonomos) ---
ANTHROPIC_API_KEY=sk-ant-api03-TU_KEY_AQUI

# --- GitHub (obligatorio para publicacion automatica de articulos) ---
GITHUB_TOKEN=ghp_TU_TOKEN_AQUI

# --- Google Analytics (obligatorio para tracking) ---
NEXT_PUBLIC_GA_ID=G-TU_CODIGO

# --- Google Search Console (ya configurado en layout.tsx) ---
GOOGLE_SITE_VERIFICATION=tu_codigo_de_verificacion

# --- Vercel (para deploy automatico) ---
VERCEL_TOKEN=vcp_TU_TOKEN
VERCEL_SCOPE=tu-scope

# ============================================
# NOTAS:
# - ANTHROPIC_API_KEY: Crear en console.anthropic.com
# - GITHUB_TOKEN: Crear en github.com/settings/tokens
# - Estas variables se configuran en Vercel > Settings > Environment Variables
# - NUNCA subir .env.local al repositorio
# ============================================
